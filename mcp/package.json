{
  "name": "chronoshield-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for ChronoShield API — preflight datetime validation for AI agents. Detects DST gaps, DST overlaps, and invalid IANA timezones before agents schedule, book, bill, remind, or convert.",
  "type": "module",
  "bin": {
    "chronoshield-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chronoshield",
    "timezone",
    "datetime",
    "dst",
    "daylight-saving",
    "iana",
    "ai-agents",
    "agent-tools",
    "claude",
    "claude-desktop",
    "cursor",
    "windsurf"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "license": "ISC",
  "author": "Mike Mait",
  "homepage": "https://chronoshieldapi.com/docs/ai-agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mike-Mait/ChronoShield-API.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/Mike-Mait/ChronoShield-API/issues"
  }
}
